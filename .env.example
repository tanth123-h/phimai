# Render web service
DATABASE_URL=postgresql://user:password@host:5432/database
PORT=8000
ENABLE_CAMERA_WORKER=false
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=*
DEFAULT_CAMERA_LIMIT=30

# Local AI service authentication
LOCAL_INGEST_TOKEN=change-this-shared-token

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=
LINE_ALERT_COOLDOWN_SECONDS=300

# Local AI worker only
RENDER_API_URL=https://your-render-service.onrender.com
CAMERA_ID=main-prang
CAMERA_NAME=ปรางค์ประธาน
CAMERA_LIMIT=30
RTSP_URL=rtsp://user:password@camera-private-ip:554/stream2
YOLO_MODEL_PATH=yolov8m.pt
POST_EVERY_N_FRAMES=5

# Optional Render-side RTSP metadata for two default cameras.
# Render should still keep ENABLE_CAMERA_WORKER=false unless the cameras are reachable from Render.
CAMERA_MAIN_PRANG_RTSP_URL=
CAMERA_SOUTH_GOPURA_RTSP_URL=
