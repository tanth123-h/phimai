# Local/ngrok server
PORT=8000
ENABLE_CAMERA_WORKER=true
LOG_LEVEL=INFO
DEFAULT_CAMERA_LIMIT=30
YOLO_MODEL_PATH=yolov8m.pt

# Camera RTSP URLs. You can also edit these from the staff dashboard.
CAMERA_MAIN_PRANG_RTSP_URL=rtsp://user:password@camera-private-ip:554/stream2
CAMERA_SOUTH_GOPURA_RTSP_URL=rtsp://user:password@second-camera-private-ip:554/stream2

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=
LINE_ALERT_COOLDOWN_SECONDS=300
